# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# Local example: postgresql://user:password@localhost:5432/fintrack
# Neon / Supabase: paste the connection string from the dashboard.
# Vercel + Neon: use the *pooled* connection string for DATABASE_URL.
DATABASE_URL="postgresql://user:password@localhost:5432/fintrack"

# ─── NextAuth.js v5 ────────────────────────────────────────────────────────────
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Local: http://localhost:3000  | Production: your full https URL.
NEXTAUTH_URL="http://localhost:3000"

# ─── OpenAI (AI insights, anomaly, NL query, report generator) ────────────────
OPENAI_API_KEY=""

# ─── Google OAuth (optional — enables "Continue with Google") ─────────────────
# https://console.cloud.google.com/apis/credentials
# Redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
